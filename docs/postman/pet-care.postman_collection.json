      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login success', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.environment.set('admin_token', json.data.access_token);",
                  "}"

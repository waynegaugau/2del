  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('run_suffix')) {",
          "  const suffix = Date.now().toString();",
          "  pm.environment.set('run_suffix', suffix);",
          "  pm.environment.set('owner_username', `owner_${suffix}`);",
          "  pm.environment.set('owner_email', `owner_${suffix}@example.com`);",
          "  pm.environment.set('staff_username', `staff_${suffix}`);",
          "  pm.environment.set('staff_email', `staff_${suffix}@example.com`);",
          "}"
        ]
      }
    }
  ],

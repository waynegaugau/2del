    "_postman_id": "55312b64-fdbb-4b72-9296-6d25ad8bb001",
    "name": "Pet Care API",
    "description": "End-to-end Postman collection for the Pet Care backend. Run requests in order after setting admin_username and admin_password in the environment.",
